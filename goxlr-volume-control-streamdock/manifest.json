        "muteFader": "A",
        "muteTarget": "MutedToAll",
        "muteEnabled": true
      },
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false,
      "PropertyInspectorPath": "inspector.html"
    }
  ],
  "Version": "1.4.0",
